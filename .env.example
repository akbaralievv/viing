# Скопируйте в .env.local и заполните значения

# URL продакшн-сайта (без хвостового слэша) — используется в SEO/OpenGraph
NEXT_PUBLIC_SITE_URL=https://viing.uz

# Доставка форм в Telegram-бот:
# 1) Создайте бота через @BotFather, получите токен
# 2) Узнайте chat_id (например, через @userinfobot) — это может быть личный аккаунт или ID группы
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Аналитика (опционально)
# NEXT_PUBLIC_YANDEX_METRIKA_ID=
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
